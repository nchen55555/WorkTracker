{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/worktracker", "destination": "/index.html" },
    { "source": "/worktracker/privacy", "destination": "/privacy.html" },
    { "source": "/worktracker/public/:path*", "destination": "/public/:path*" },
    { "source": "/worktracker/Niche.dmg", "destination": "/public/Niche.dmg" },
    { "source": "/worktracker/app/assets/:path*", "destination": "/app/assets/:path*" },
    { "source": "/worktracker/app/icon.png", "destination": "/app/icon.png" },
    { "source": "/worktracker/app/:path*", "destination": "/app/index.html" },
    { "source": "/worktracker/app", "destination": "/app/index.html" }
  ]
}
